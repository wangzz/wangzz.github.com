#! /bin/zsh

# 切换到兼容的 Node 版本（Hexo 3.9.0 不兼容 Node 14+）
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
nvm use 10
echo "Node version: $(node -v)"

# git pull source
echo "**************BEGIN GIT PULL SOURCE**************"
git pull origin source

if [ $? != 0 ]
then
echo "**************GIT PULL SOURCE FAILED**************"
exit 1
else
echo "**************GIT PULL SOURCE SUCCESS**************"
fi


# hexo generate
echo "**************BEGIN HEXO GENERATE**************"
npx hexo clean

# 使用 Node.js 脚本生成，修复 hexo generate 在 Node 20 下输出 0 字节的问题
node -e "
const Hexo = require('hexo');
const fs = require('fs');
const path = require('path');
const hexo = new Hexo(process.cwd(), {});
hexo.init().then(() => hexo.load()).then(() => {
  const routes = hexo.route.list();
  return Promise.all(routes.map(route => new Promise((resolve, reject) => {
    const stream = hexo.route.get(route);
    let data = '';
    stream.on('data', chunk => data += chunk);
    stream.on('end', () => {
      const filePath = path.join('public', route);
      fs.mkdirSync(path.dirname(filePath), {recursive: true});
      fs.writeFileSync(filePath, data);
      resolve();
    });
    stream.on('error', reject);
  })));
}).then(() => {
  console.log('Hexo generate done');
}).catch(err => {
  console.error('Hexo generate error:', err);
  process.exit(1);
});
"

if [ $? != 0 ]
then
echo "**************HEXO GENERATE FAILED**************"
exit 1
else
echo "**************HEXO GENERATE SUCCESS**************"
fi


# Copy static pairing page (skip_render creates empty files, so copy manually)
echo "**************COPY STATIC PAGES BEGIN**************"
mkdir -p public/doc/PhoneClaw
cp source/doc/PhoneClaw/pairing.html public/doc/PhoneClaw/pairing.html
echo "**************COPY STATIC PAGES SUCCESS**************"


# git push source
echo "**************GIT PUSH SOURCE BEGIN**************"
git add --all .
git commit -m "update at `date` "
git push origin source
if [ $? != 0 ]
then
echo "**************GIT PUSH SOURCE FAILED**************"
exit 1
else
echo "**************GIT PUSH SOURCE SUCCESS**************"
fi


# 创建发布用 git 仓库
cd public
git init -b master
git add .

if [ -n "$1" ];
then
git commit -m "$1"
else
git commit -m "update at `date`"
fi

# 添加云服务器源
echo "**************PUSH TO CLOUD BEGIN**************"
# 改变云服务器 remote url
git remote add cloud git@81.70.132.212:/home/git/hexo.git
# 提交博客内容
git push -u cloud master -f

if [ $? != 0 ]
then
echo "**************PUSH TO CLOUD FAILED**************"
exit 1
else
echo "**************PUSH TO CLOUD SUCCESS**************"
fi

# 添加 github 源
echo "**************PUSH TO GITHUB BEGIN**************"
# 改变 github remote url
git remote add origin git@github.com:wangzz/wangzz.github.com.git >> /dev/null 2>&1
# 提交博客内容
git push origin master -f

if [ $? != 0 ]
then
echo "**************PUSH TO GITHUB FAILED**************"
exit 1
else
echo "**************PUSH TO GITHUB SUCCESS**************"
fi

cd -

echo "**************DONE**************"